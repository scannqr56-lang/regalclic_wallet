# RegalClic Wallet V1 — Variables d'environnement
# Copier vers .env à la racine du projet

# Supabase (frontend Vite)
VITE_SUPABASE_URL=https://pfutrevqneggudriiyxr.supabase.co
VITE_SUPABASE_ANON_KEY=

# URL publique de l'app — uniquement utile en dev local (npm run dev)
# En prod, le QR utilise automatiquement l'URL du site (ex. https://regalclic-wallet.vercel.app)
# VITE_PUBLIC_APP_URL=http://localhost:5173

# Domaine racine (optionnel, multi-tenant futur)
# VITE_PUBLIC_ROOT_DOMAIN=regalclic.app

# --- Secrets Supabase Edge Functions (dashboard Supabase > Edge Functions > Secrets) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Apple Wallet
# APPLE_PASS_TYPE_IDENTIFIER=pass.com.regalclic.loyalty
# APPLE_TEAM_ID=
# APPLE_ORGANIZATION_NAME=RegalClic
# APPLE_SIGNER_CERT_PEM=
# APPLE_SIGNER_KEY_PEM=
# APPLE_WWDR_CERT_PEM=
# APPLE_APNS_KEY_ID=
# APPLE_APNS_KEY_PEM=
# APPLE_APNS_TEAM_ID=
# APPLE_APNS_USE_SANDBOX=true

# Google Wallet
# GOOGLE_WALLET_ISSUER_ID=
# GOOGLE_WALLET_CLASS_SUFFIX=regalclic_loyalty
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# GOOGLE_WALLET_REVIEW_STATUS=UNDER_REVIEW
