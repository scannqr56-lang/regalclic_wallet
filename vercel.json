{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "regalclic.app" }],
      "destination": "https://www.regalclic.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
